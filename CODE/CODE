function renderDistricts(list) {
  const container = document.getElementById('districts-container');
  const noResult  = document.getElementById('no-result');
  if (!list.length) { container.innerHTML = ''; noResult.style.display = 'block'; return; }
  noResult.style.display = 'none';
  container.innerHTML = list.map((d, i) => buildCard(d, i)).join('');
}

function filterDistricts() {
  const q = document.getElementById('district-search').value.trim().toLowerCase();
  // Reset division tabs
  document.querySelectorAll('.dist-tab').forEach(t => t.classList.remove('active'));
  document.querySelector('.dist-tab').classList.add('active');
  const filtered = mpDistricts.filter(d => d.name.toLowerCase().includes(q) || d.division.includes(q));
  renderDistricts(filtered);
}

function filterByDiv(div, el) {
  document.getElementById('district-search').value = '';
  document.querySelectorAll('.dist-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  const filtered = div === 'all' ? mpDistricts : mpDistricts.filter(d => d.division === div);
  renderDistricts(filtered);
}

// Initial render — all districts
renderDistricts(mpDistricts);

