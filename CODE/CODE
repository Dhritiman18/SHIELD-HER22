// SAFETY SCORE PREDICTOR
// ═══════════════════════════════════════
const safetyDict = {
  "mp nagar":78,"tt nagar":72,"new market":70,"arera colony":80,
  "chowk bazaar":42,"bus stand":50,"railway station":52,"civil lines":82,
  "isolated lane":16,"dark alley":14,"market area":60,"residential":74,
  "indore":65,"bhopal":70,"gwalior":58,"jabalpur":62,"ujjain":60,
  "morena":45,"bhind":43,"rewa":55,"sagar":58,"katni":52
};

const riskTuple = ["Time of Day","Area Type","Street Lighting","Crowd Density","Police Proximity"];

function predictSafety() {
  const area     = document.getElementById('pred-area').value.trim().toLowerCase();
  const district = document.getElementById('pred-district').value.toLowerCase();
  const time     = document.getElementById('pred-time').value;
  const atype    = document.getElementById('pred-areatype').value;

  // Dictionary lookup
  let base = safetyDict[area] || safetyDict[district] || 62;

  // Time penalty (tuple-driven)
  const timePenalty = {day:0, evening:-8, night:-20, latenight:-32};
  // Area type penalty
  const typePenalty = {market:+6, residential:+4, isolated:-28, transport:-10, govt:+10};

  let score = base + (timePenalty[time]||0) + (typePenalty[atype]||0);
  score = Math.max(8, Math.min(100, Math.round(score)));

  // Set → unique alerts (no duplicates)
  const alertSet = new Set();
  if (time === 'night' || time === 'latenight') alertSet.add("🌙 Avoid travelling alone after 9PM");
  if (atype === 'isolated') { alertSet.add("⚠️ This area type is HIGH RISK — avoid alone"); alertSet.add("📍 Share live location immediately"); }
  if (atype === 'transport') alertSet.add("🚌 Stay in well-lit sections of transport hubs");
  if (score < 40) { alertSet.add("🚨 HIGH RISK — call 112 if you feel unsafe"); alertSet.add("👥 Do NOT be alone here"); }
  if (score < 60) alertSet.add("📱 Keep 112 ready on speed dial");
  alertSet.add("🗺️ Share your live Google Maps location with family");
  alertSet.add("🔋 Ensure your phone is fully charged");

  // Show result
  document.getElementById('pred-result').style.display = 'block';
  document.getElementById('pred-result').scrollIntoView({behavior:'smooth', block:'nearest'});

  // Animate score ring
  const circle  = document.getElementById('score-circle');
  const numEl   = document.getElementById('score-num');
  const labelEl = document.getElementById('score-label');
  const subEl   = document.getElementById('score-sub');

  const circumference = 2 * Math.PI * 68; // 427
  const offset = circumference - (score / 100) * circumference;
  let color = score >= 70 ? '#00e676' : score >= 45 ? '#ffd600' : '#ff3d8b';
  circle.style.stroke = color;
  circle.style.strokeDashoffset = offset;
  numEl.textContent = score;
  numEl.style.color = color;

  if (score >= 70) { labelEl.textContent = '✅ Relatively Safe'; labelEl.style.color = '#00e676'; subEl.textContent = 'Stay alert and follow standard precautions'; }
  else if (score >= 45) { labelEl.textContent = '⚠️ Moderate Risk'; labelEl.style.color = '#ffd600'; subEl.textContent = 'Extra caution advised — stay aware at all times'; }
  else { labelEl.textContent = '🚨 High Risk Area'; labelEl.style.color = '#ff3d8b'; subEl.textContent = 'Avoid this area alone — take immediate precautions'; }

  // Risk factors breakdown
  const rfVals = [
    {name:'Time of Day', val: time==='day'?90:time==='evening'?65:time==='night'?35:15, color:'#00bcd4'},
    {name:'Area Type', val: atype==='govt'?88:atype==='residential'?78:atype==='market'?65:atype==='transport'?52:20, color:'#7c3aed'},
    {name:'Street Lighting', val: atype==='isolated'?20:time==='day'?95:60, color:'#ffd600'},
    {name:'Crowd Density', val: atype==='market'?80:atype==='transport'?65:atype==='isolated'?10:50, color:'#ff7043'},
    {name:'Police Proximity', val: district==='bhopal'||district==='indore'?75:55, color:'#00e676'},
  ];
  document.getElementById('risk-factors').innerHTML = `
    <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;color:#f0eafb;margin-bottom:12px;">📐 Risk Factor Analysis <span style="font-size:.7rem;color:#a09ab8;font-weight:500;">(Tuple-driven)</span></div>
    ${rfVals.map(r=>`
      <div style="margin-bottom:10px;">
        <div style="display:flex;justify-content:space-between;font-size:.78rem;color:#a09ab8;margin-bottom:4px;"><span>${r.name}</span><span style="color:${r.color};font-weight:700;">${r.val}%</span></div>
        <div style="background:rgba(255,255,255,.06);border-radius:50px;height:7px;">
          <div style="background:${r.color};width:${r.val}%;height:7px;border-radius:50px;transition:width 1s ease;"></div>
        </div>
      </div>`).join('')}`;

  // Alerts (Set)
  document.getElementById('alert-set').innerHTML = `
    <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;color:#f0eafb;margin-bottom:10px;">🔵 Active Safety Alerts <span style="font-size:.7rem;color:#a09ab8;font-weight:500;">(Set — ${alertSet.size} unique)</span></div>
    <div style="display:flex;flex-direction:column;gap:7px;">
      ${[...alertSet].map(a=>`<div style="background:rgba(255,255,255,.04);border-left:3px solid #ff3d8b;border-radius:0 9px 9px 0;padding:9px 14px;font-size:.82rem;color:#f0eafb;">${a}</div>`).join('')}
    </div>`;

  // Recommendations
  document.getElementById('recommendations').innerHTML = `
    <div style="background:rgba(0,230,118,.08);border:1px solid rgba(0,230,118,.2);border-radius:12px;padding:16px;">
      <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;color:#00e676;margin-bottom:8px;">✅ Recommended Actions</div>
      <div style="font-size:.8rem;color:#a09ab8;line-height:1.8;">
        ${score < 40 ? '🚨 Leave immediately if possible. Call 112 now. Do NOT be alone.<br/>' : ''}
        📍 Share Google Maps live location with a family member before entering this area.<br/>
        📞 Save 112, 100, 181, 1090 on speed dial.<br/>
        🔋 Keep your phone charged and mobile data ON.<br/>
        ${atype==='isolated'?'🚫 Avoid this area type — especially alone or after dark.<br/>':''}
        ${time==='night'||time==='latenight'?'🌙 Night travel: take only verified cabs, share ride details.<br/>':''}
      </div>
    </div>`;
}

