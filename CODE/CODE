
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ShieldHer — Women Safety Portal | Madhya Pradesh</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<style>
:root{--pink:#ff3d8b;--orange:#ff7043;--yellow:#ffd600;--purple:#7c3aed;--teal:#00bcd4;--green:#00e676;--dark:#0d0d1a;--card-bg:#13132a;--text:#f0eafb;--muted:#a09ab8;--border:rgba(255,255,255,0.08);}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--text);overflow-x:hidden;}
::-webkit-scrollbar{width:6px;}::-webkit-scrollbar-track{background:#0d0d1a;}::-webkit-scrollbar-thumb{background:var(--pink);border-radius:3px;}
nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:14px 36px;background:rgba(13,13,26,0.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);}
.logo{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;background:linear-gradient(90deg,var(--pink),var(--orange),var(--yellow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.nav-links{display:flex;gap:16px;list-style:none;}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.78rem;font-weight:500;transition:color .2s;}
.nav-links a:hover{color:var(--pink);}
.sos-nav{background:var(--pink);color:#fff;border:none;padding:9px 20px;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;cursor:pointer;box-shadow:0 0 20px rgba(255,61,139,.5);animation:pulse-nav 2s infinite;transition:transform .2s;}
.sos-nav:hover{transform:scale(1.05);}
@keyframes pulse-nav{0%,100%{box-shadow:0 0 20px rgba(255,61,139,.5);}50%{box-shadow:0 0 40px rgba(255,61,139,.9);}}
#home{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden;padding:120px 48px 80px;text-align:center;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 20% 40%,rgba(255,61,139,.18) 0%,transparent 60%),radial-gradient(ellipse 60% 80% at 80% 60%,rgba(124,58,237,.2) 0%,transparent 60%),var(--dark);}
.floating-shapes{position:absolute;inset:0;pointer-events:none;}
.shape{position:absolute;border-radius:50%;animation:float 6s ease-in-out infinite;opacity:.12;}
.shape:nth-child(1){width:320px;height:320px;background:var(--pink);top:8%;left:3%;animation-delay:0s;}
.shape:nth-child(2){width:220px;height:220px;background:var(--purple);top:55%;right:5%;animation-delay:2s;}
.shape:nth-child(3){width:160px;height:160px;background:var(--teal);bottom:8%;left:28%;animation-delay:4s;}
.shape:nth-child(4){width:110px;height:110px;background:var(--yellow);top:18%;right:22%;animation-delay:1s;}
@keyframes float{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-30px) scale(1.05);}}
.hero-badge{display:inline-block;background:rgba(255,61,139,.15);border:1px solid rgba(255,61,139,.4);color:var(--pink);padding:8px 20px;border-radius:50px;font-size:.82rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;margin-bottom:28px;animation:fadeUp .8s ease both;}
.hero-title{font-family:'Syne',sans-serif;font-size:clamp(2.6rem,7vw,5.2rem);font-weight:800;line-height:1.05;margin-bottom:24px;animation:fadeUp .8s ease .15s both;}
.hero-title span{background:linear-gradient(90deg,var(--pink),var(--orange),var(--yellow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hero-sub{font-size:1.1rem;color:var(--muted);max-width:600px;line-height:1.7;margin-bottom:48px;animation:fadeUp .8s ease .3s both;}
.hero-ctas{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;animation:fadeUp .8s ease .45s both;}
.btn-primary{background:linear-gradient(135deg,var(--pink),var(--orange));color:#fff;border:none;padding:15px 34px;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;cursor:pointer;box-shadow:0 8px 32px rgba(255,61,139,.4);transition:transform .2s,box-shadow .2s;text-decoration:none;display:inline-block;}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(255,61,139,.5);}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border);padding:15px 34px;border-radius:50px;font-family:'Syne',sans-serif;font-weight:600;font-size:.95rem;cursor:pointer;transition:border-color .2s,background .2s;text-decoration:none;display:inline-block;}
.btn-outline:hover{border-color:var(--pink);background:rgba(255,61,139,.1);}
@keyframes fadeUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
.helpline-strip{padding:16px 36px;background:linear-gradient(90deg,var(--pink),var(--purple),var(--teal));display:flex;align-items:center;justify-content:center;gap:28px;flex-wrap:wrap;}
.helpline-item .num{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:#fff;}
.helpline-item .label{font-size:.72rem;color:rgba(255,255,255,.9);font-weight:500;}
section{padding:76px 44px;}
.section-tag{display:inline-block;font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:5px 14px;border-radius:50px;margin-bottom:14px;}
.section-title{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;line-height:1.1;margin-bottom:14px;}
.section-sub{color:var(--muted);font-size:.92rem;max-width:540px;line-height:1.75;margin-bottom:40px;}
/* HELPLINES */
#helplines{background:var(--card-bg);}
.helplines-category{margin-bottom:44px;}
.category-title{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:18px;padding-bottom:10px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;}
.helplines-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:14px;}
.helpline-card{background:var(--dark);border:1px solid var(--border);border-radius:16px;padding:20px 22px;display:flex;gap:16px;transition:transform .3s,border-color .3s,box-shadow .3s;cursor:pointer;align-items:flex-start;}
.helpline-card:hover{transform:translateY(-5px);border-color:var(--pink);box-shadow:0 12px 40px rgba(255,61,139,.2);}
.hc-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;}
.hc-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:3px;}
.hc-number{font-size:1.6rem;font-weight:800;font-family:'Syne',sans-serif;line-height:1.1;}
.hc-desc{font-size:.76rem;color:var(--muted);margin-top:5px;line-height:1.55;}
.hc-badge{display:inline-block;font-size:.62rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:2px 8px;border-radius:50px;margin-top:5px;}
/* SOS */
#sos{background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(255,61,139,.12),var(--dark));text-align:center;}
.sos-setup-panel{max-width:480px;margin:0 auto 36px;background:var(--card-bg);border:1px solid var(--border);border-radius:18px;padding:26px;}
.sos-setup-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;margin-bottom:14px;color:var(--yellow);}
.sos-input{background:var(--dark);border:1px solid var(--border);border-radius:10px;padding:11px 15px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.88rem;width:100%;outline:none;margin-bottom:9px;transition:border-color .2s;}
.sos-input:focus{border-color:var(--pink);}
.sos-save-btn{background:var(--pink);color:#fff;border:none;padding:12px 28px;border-radius:10px;font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;cursor:pointer;width:100%;margin-top:2px;transition:background .2s;}
.sos-save-btn:hover{background:#ff1a77;}
.sos-saved-msg{font-size:.78rem;color:var(--green);margin-top:7px;display:none;}
.sos-ring-wrap{display:flex;align-items:center;justify-content:center;margin:0 auto 28px;position:relative;width:230px;height:230px;}
.sos-ring{position:absolute;border-radius:50%;border:2px solid rgba(255,61,139,.3);animation:sos-ripple 2.5s ease-out infinite;}
.sos-ring:nth-child(1){width:230px;height:230px;animation-delay:0s;}
.sos-ring:nth-child(2){width:180px;height:180px;animation-delay:.7s;}
.sos-ring:nth-child(3){width:130px;height:130px;animation-delay:1.4s;}
@keyframes sos-ripple{0%{transform:scale(.8);opacity:1;}100%{transform:scale(1.4);opacity:0;}}
.sos-btn-main{position:absolute;width:105px;height:105px;border-radius:50%;background:linear-gradient(135deg,#ff3d8b,#ff1744);border:none;cursor:pointer;font-family:'Syne',sans-serif;font-weight:800;font-size:.9rem;color:#fff;box-shadow:0 0 60px rgba(255,61,139,.7);transition:transform .15s;user-select:none;}
.sos-btn-main:active{transform:scale(.95);}
#sos-status{margin-top:8px;font-size:.92rem;color:var(--muted);min-height:80px;transition:color .3s;padding:0 16px;line-height:1.7;}
.sos-features{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:24px;}
.sos-feat{background:var(--card-bg);border:1px solid var(--border);border-radius:12px;padding:14px 20px;display:flex;align-items:center;gap:10px;font-size:.82rem;font-weight:500;}
.sos-feat span{font-size:1.2rem;}
.location-display{background:var(--card-bg);border:1px solid rgba(0,230,118,.3);border-radius:12px;padding:14px 22px;margin:16px auto 0;max-width:540px;font-size:.83rem;color:var(--green);display:none;}
/* PREVENTIVE */
#preventive{background:var(--card-bg);}
.prev-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px;}
.prev-tab{background:var(--dark);border:1px solid var(--border);border-radius:50px;padding:9px 20px;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .2s;color:var(--muted);}
.prev-tab.active{background:var(--pink);color:#fff;border-color:var(--pink);}
.prev-panel{display:none;}
.prev-panel.active{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;}
.prev-card{background:var(--dark);border:1px solid var(--border);border-radius:16px;padding:22px;transition:transform .3s,box-shadow .3s;position:relative;overflow:hidden;}
.prev-card:hover{transform:translateY(-5px);box-shadow:0 16px 44px rgba(0,0,0,.4);}
.prev-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;}
.prev-card:nth-child(odd)::after{background:linear-gradient(90deg,var(--pink),var(--orange));}
.prev-card:nth-child(even)::after{background:linear-gradient(90deg,var(--purple),var(--teal));}
.prev-icon{font-size:1.9rem;margin-bottom:10px;}
.prev-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.97rem;margin-bottom:7px;}
.prev-text{font-size:.82rem;color:var(--muted);line-height:1.6;margin-bottom:8px;}
.prev-points{list-style:none;display:flex;flex-direction:column;gap:5px;}
.prev-points li{font-size:.8rem;color:var(--muted);padding-left:15px;position:relative;line-height:1.5;}
.prev-points li::before{content:'▸';position:absolute;left:0;color:var(--pink);font-size:.68rem;top:2px;}
/* TIPS */
#tips{background:var(--dark);}
.tips-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;}
.tip-card{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:24px;position:relative;overflow:hidden;transition:transform .3s,box-shadow .3s;}
.tip-card:hover{transform:translateY(-5px);box-shadow:0 18px 48px rgba(0,0,0,.4);}
.tip-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.tip-card:nth-child(1)::before{background:linear-gradient(90deg,var(--pink),var(--orange));}
.tip-card:nth-child(2)::before{background:linear-gradient(90deg,var(--purple),var(--teal));}
.tip-card:nth-child(3)::before{background:linear-gradient(90deg,var(--teal),var(--green));}
.tip-card:nth-child(4)::before{background:linear-gradient(90deg,var(--yellow),var(--orange));}
.tip-card:nth-child(5)::before{background:linear-gradient(90deg,var(--green),var(--teal));}
.tip-card:nth-child(6)::before{background:linear-gradient(90deg,var(--orange),var(--pink));}
.tip-card:nth-child(7)::before{background:linear-gradient(90deg,var(--purple),var(--pink));}
.tip-card:nth-child(8)::before{background:linear-gradient(90deg,var(--teal),var(--yellow));}
.tip-num{font-family:'Syne',sans-serif;font-size:2.6rem;font-weight:800;color:rgba(255,255,255,.06);position:absolute;top:12px;right:16px;}
.tip-icon{font-size:1.8rem;margin-bottom:10px;}
.tip-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.97rem;margin-bottom:7px;}
.tip-text{font-size:.82rem;color:var(--muted);line-height:1.65;}
/* NEARBY */
#nearby{background:var(--card-bg);}
.mp-district-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;}
.dist-tab{background:var(--dark);border:1px solid var(--border);border-radius:50px;padding:7px 16px;font-size:.78rem;font-weight:600;cursor:pointer;transition:all .2s;color:var(--muted);}
.dist-tab.active{background:var(--teal);color:#1a1a2e;border-color:var(--teal);}
.nearby-layout{display:grid;grid-template-columns:1fr 1.3fr;gap:24px;align-items:start;}
.map-placeholder{background:var(--dark);border:1px solid var(--border);border-radius:20px;height:380px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;position:relative;overflow:hidden;}
.map-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(0,188,212,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(0,188,212,.06) 1px,transparent 1px);background-size:34px 34px;}
.map-pin{font-size:2.6rem;animation:bounce 1.5s ease infinite;z-index:1;}
@keyframes bounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}
.map-label{font-family:'Syne',sans-serif;font-size:.97rem;font-weight:700;z-index:1;}
.map-sublabel{font-size:.75rem;color:var(--muted);z-index:1;}
.map-coords{font-size:.7rem;color:var(--teal);z-index:1;font-family:monospace;}
.nearby-list{display:flex;flex-direction:column;gap:10px;max-height:400px;overflow-y:auto;padding-right:4px;}
.nearby-list::-webkit-scrollbar{width:4px;}
.nearby-list::-webkit-scrollbar-thumb{background:var(--teal);border-radius:2px;}
.nearby-item{background:var(--dark);border:1px solid var(--border);border-radius:13px;padding:14px 16px;display:flex;align-items:center;gap:12px;transition:border-color .3s,transform .3s;}
.nearby-item:hover{border-color:var(--teal);transform:translateX(5px);}
.ni-icon{font-size:1.5rem;width:38px;text-align:center;flex-shrink:0;}
.ni-name{font-family:'Syne',sans-serif;font-weight:700;font-size:.84rem;margin-bottom:2px;}
.ni-dist{font-size:.7rem;color:var(--muted);}
.ni-phone{font-size:.7rem;color:var(--teal);margin-top:1px;}
.ni-btn{margin-left:auto;background:rgba(0,188,212,.15);border:1px solid rgba(0,188,212,.3);color:var(--teal);padding:6px 13px;border-radius:50px;font-size:.7rem;font-weight:600;cursor:pointer;transition:background .2s;white-space:nowrap;text-decoration:none;}
.ni-btn:hover{background:rgba(0,188,212,.3);}
/* DEFENSE */
#selfdefense{background:var(--dark);}
.defense-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;}
.defense-card{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:24px;transition:transform .3s,box-shadow .3s;}
.defense-card:hover{transform:translateY(-5px);box-shadow:0 18px 48px rgba(0,0,0,.4);}
.dc-header{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
.dc-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;}
.dc-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.97rem;}
.dc-level{font-size:.7rem;color:var(--muted);margin-top:2px;}
.dc-steps{list-style:none;display:flex;flex-direction:column;gap:8px;}
.dc-steps li{font-size:.81rem;color:var(--muted);line-height:1.6;padding-left:17px;position:relative;}
.dc-steps li::before{content:'→';position:absolute;left:0;font-weight:700;font-size:.7rem;color:var(--orange);}
/* RIGHTS */
#rights{background:var(--card-bg);}
.rights-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(275px,1fr));gap:16px;}
.right-card{background:var(--dark);border:1px solid var(--border);border-radius:16px;padding:24px;transition:transform .3s,border-color .3s;}
.right-card:hover{transform:translateY(-5px);border-color:var(--purple);}
.rc-tag{display:inline-block;font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 11px;border-radius:50px;margin-bottom:11px;}
.rc-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;margin-bottom:8px;}
.rc-text{font-size:.81rem;color:var(--muted);line-height:1.65;}
.rc-year{font-size:.71rem;color:var(--muted);margin-top:11px;padding-top:9px;border-top:1px solid var(--border);}
/* REPORT */
#report{background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(124,58,237,.1),var(--dark));}
.report-wrap{max-width:680px;margin:0 auto;background:var(--card-bg);border:1px solid var(--border);border-radius:24px;padding:40px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.form-group{display:flex;flex-direction:column;gap:7px;}
.form-group.full{grid-column:1/-1;}
.form-label{font-size:.76rem;font-weight:600;color:var(--muted);letter-spacing:.04em;text-transform:uppercase;}
.form-input,.form-select,.form-textarea{background:var(--dark);border:1px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;transition:border-color .2s,box-shadow .2s;width:100%;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--purple);box-shadow:0 0 0 3px rgba(124,58,237,.2);}
.form-textarea{resize:vertical;min-height:105px;}
.form-select option{background:var(--card-bg);}
.anonymous-check{display:flex;align-items:center;gap:12px;background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.3);border-radius:11px;padding:13px 17px;cursor:pointer;}
.anonymous-check input{width:16px;height:16px;accent-color:var(--purple);cursor:pointer;}
.anonymous-check label{font-size:.86rem;font-weight:500;cursor:pointer;}
.submit-btn{width:100%;padding:16px;background:linear-gradient(135deg,var(--purple),var(--pink));border:none;border-radius:12px;color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:.97rem;letter-spacing:.04em;cursor:pointer;margin-top:8px;box-shadow:0 8px 32px rgba(124,58,237,.4);transition:transform .2s,box-shadow .2s;}
.submit-btn:hover{transform:translateY(-2px);box-shadow:0 14px 40px rgba(124,58,237,.5);}
#form-success{display:none;text-align:center;padding:22px;color:var(--green);font-family:'Syne',sans-serif;font-weight:700;font-size:1.05rem;line-height:1.9;}
footer{background:#0a0a14;border-top:1px solid var(--border);padding:36px 44px;text-align:center;}
.footer-logo{font-family:'Syne',sans-serif;font-size:1.35rem;font-weight:800;background:linear-gradient(90deg,var(--pink),var(--orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:10px;}
.footer-text{color:var(--muted);font-size:.82rem;line-height:1.75;}
.footer-hotlines{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:18px;}
.fh-item{background:rgba(255,61,139,.1);border:1px solid rgba(255,61,139,.25);border-radius:9px;padding:9px 18px;font-size:.8rem;}
.fh-item strong{color:var(--pink);font-family:'Syne',sans-serif;}
.reveal{opacity:0;transform:translateY(36px);transition:opacity .7s ease,transform .7s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
@media(max-width:900px){nav{padding:12px 18px;}.nav-links{display:none;}section{padding:56px 18px;}.helpline-strip{padding:12px 18px;gap:12px;}.nearby-layout{grid-template-columns:1fr;}.form-grid{grid-template-columns:1fr;}.report-wrap{padding:24px 16px;}.hero-ctas{flex-direction:column;align-items:center;}}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">🛡️ ShieldHer MP</div>
  <ul class="nav-links">
    <li><a href="#predictor">🔥 Safety Score</a></li>
    <li><a href="#charts">📊 Charts</a></li>
    <li><a href="#helplines">Helplines</a></li>
    <li><a href="#sos">SOS</a></li>
    <li><a href="#preventive">Preventive</a></li>
    <li><a href="#tips">Tips</a></li>
    <li><a href="#nearby">MP Locations</a></li>
    <li><a href="#selfdefense">Self Defense</a></li>
    <li><a href="#rights">Rights</a></li>
    <li><a href="#report">Report</a></li>
  </ul>
