  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(pos => {
      document.getElementById('gps-status').textContent = '📍 GPS Ready: ' + pos.coords.latitude.toFixed(4) + ', ' + pos.coords.longitude.toFixed(4);
    }, () => {
      document.getElementById('gps-status').textContent = '📍 GPS: Enable location for SOS';
    });
  }
}

function startSOS() {
  sosTimer = setTimeout(() => {
    navigator.geolocation.getCurrentPosition(pos => {
      const lat = pos.coords.latitude, lng = pos.coords.longitude;
      const msg = `🆘 SOS ALERT from ${contacts.name || 'Unknown'}!\nLocation: https://maps.google.com/?q=${lat},${lng}\nSend help immediately!`;
      const num = contacts.parent ? contacts.parent.replace(/\D/g,'') : '';
      if (num) window.open(`https://wa.me/${num}?text=${encodeURIComponent(msg)}`);
      window.open('tel:112');
    }, () => {
      window.open('tel:112');
    });
  }, 3000);
}

function cancelSOS() { if (sosTimer) clearTimeout(sosTimer); }

// ── PREVENTIVE TABS ──
function switchTab(id, el) {
  document.querySelectorAll('.preventive-content').forEach(c => c.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('prev-' + id).classList.add('active');
  el.classList.add('active');
}

// ── DISTRICTS ──
function filterDistricts() {
  const q = document.getElementById('dist-search').value.toLowerCase();
  const cards = document.querySelectorAll('.district-card');
  let found = 0;
  cards.forEach(c => {
    const match = c.textContent.toLowerCase().includes(q);
    c.style.display = match ? '' : 'none';
    if (match) found++;
  });
  document.getElementById('no-result').style.display = found === 0 ? 'block' : 'none';
}

function filterDiv(div, el) {
  document.querySelectorAll('.dtab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  const cards = document.querySelectorAll('.district-card');
  cards.forEach(c => {
    c.style.display = (div === 'all' || c.dataset.div === div) ? '' : 'none';
  });
}

// ── REPORT ──
function submitReport() {
  document.getElementById('submit-confirm').style.display = 'block';
  document.querySelector('.submit-btn').textContent = '✅ Submitted';
  document.querySelector('.submit-btn').style.background = '#4ade80';
}

// ── PREDICTOR ──
function predictScore() {
  const area = document.getElementById('pred-area').value || 'Unknown';
  const time = document.getElementById('pred-time').value;
  const type = document.getElementById('pred-type').value;
  let score = 75;
  if (time.includes('Night')) score -= 15;
  if (time.includes('Late Night')) score -= 25;
  if (time.includes('Evening')) score -= 8;
  if (type.includes('Isolated')) score -= 20;
  if (type.includes('Market') || type.includes('Govt')) score += 8;
  if (type.includes('Mountain Trail')) score -= 10;
  if (type.includes('Transport')) score += 5;
  score = Math.max(20, Math.min(95, score + Math.floor(Math.random() * 10) - 5));

  const tips = score > 70
    ? ['Area appears relatively safe at this time', 'Continue sharing live location with family', 'Stay aware of your surroundings', 'Keep 112 ready to dial in one tap']
    : ['Consider taking a different route or time', 'Inform someone of your exact location and route', 'Avoid this area alone — go with company', 'Keep pepper spray accessible and phone charged', 'Use HRTC bus or app-based cab instead of walking'];

  const el = document.getElementById('score-display');
  const numEl = document.getElementById('score-num');
  numEl.textContent = score;
  numEl.style.color = score > 70 ? '#4ade80' : score > 50 ? 'var(--gold)' : 'var(--accent)';
  document.getElementById('score-tips').innerHTML = tips.map(t => `<li>• ${t}</li>`).join('');
  el.style.display = 'block';
}

