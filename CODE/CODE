// SAVE SOS CONTACTS
function saveContacts() {
  const pName  = document.getElementById('parent-name').value.trim();
  const pPhone = document.getElementById('parent-phone').value.trim();
  if (!pName || !pPhone) { alert('Please enter parent name and phone number.'); return; }
  localStorage.setItem('sos_p_name', pName);
  localStorage.setItem('sos_p_phone', pPhone);
  localStorage.setItem('sos_c2_name',  document.getElementById('contact2-name').value.trim());
  localStorage.setItem('sos_c2_phone', document.getElementById('contact2-phone').value.trim());
  document.getElementById('sos-saved').style.display = 'block';
}

// LOAD SAVED CONTACTS
window.addEventListener('load', () => {
  const pn = localStorage.getItem('sos_p_name');
  const pp = localStorage.getItem('sos_p_phone');
  if (pn) document.getElementById('parent-name').value = pn;
  if (pp) document.getElementById('parent-phone').value = pp;
  const c2n = localStorage.getItem('sos_c2_name');
  const c2p = localStorage.getItem('sos_c2_phone');
  if (c2n) document.getElementById('contact2-name').value = c2n;
  if (c2p) document.getElementById('contact2-phone').value = c2p;
  if (pn && pp) document.getElementById('sos-saved').style.display = 'block';
});

// SOS LOGIC
let sosInterval = null, sosCount = 3;

function startSOS(e) {
  if (e) e.preventDefault();
  const btn = document.getElementById('sosBtn');
  const status = document.getElementById('sos-status');
  sosCount = 3;
  status.style.color = '#ff3d8b';
  status.textContent = '🔴 Activating in 3...';
  btn.style.background = 'linear-gradient(135deg,#ff1744,#b71c1c)';
  sosInterval = setInterval(() => {
    sosCount--;
    if (sosCount > 0) {
      status.textContent = `🔴 Activating in ${sosCount}...`;
    } else {
      clearInterval(sosInterval);
      activateSOS();
    }
  }, 1000);
}

function cancelSOS() {
  if (sosInterval) { clearInterval(sosInterval); sosInterval = null; }
  const btn = document.getElementById('sosBtn');
  const status = document.getElementById('sos-status');
  if (sosCount > 0) {
    btn.style.background = 'linear-gradient(135deg,#ff3d8b,#ff1744)';
    btn.innerHTML = 'SOS<br/>HOLD';
    status.style.color = '';
    status.textContent = 'Hold for 3 seconds → sends your GPS to parent + calls police';
  }
}

function activateSOS() {
  const btn    = document.getElementById('sosBtn');
  const status = document.getElementById('sos-status');
  const locDiv = document.getElementById('loc-display');
  const locText= document.getElementById('loc-text');
  const pName  = localStorage.getItem('sos_p_name')  || 'Emergency Contact';
  const pPhone = localStorage.getItem('sos_p_phone') || '';
  const c2Name = localStorage.getItem('sos_c2_name') || '';
  const c2Phone= localStorage.getItem('sos_c2_phone')|| '';

  btn.style.background = 'linear-gradient(135deg,#00e676,#00bcd4)';
  btn.innerHTML = '✅<br/>SENT';

  const sendAlerts = (lat, lng) => {
    const mapsLink = `https://maps.google.com/?q=${lat},${lng}`;
    locDiv.style.display = 'block';
    locText.innerHTML = `${lat}°N, ${lng}°E &nbsp;|&nbsp; <a href="${mapsLink}" target="_blank" style="color:var(--teal);">Open in Maps ↗</a>`;

    status.style.color = '#00e676';
    status.innerHTML = `
      🚨 <strong>SOS ACTIVATED!</strong><br/>
      📍 GPS: ${lat}°N, ${lng}°E<br/>
      📲 WhatsApp alert sending to <strong>${pName}</strong>${c2Name ? ' &amp; ' + c2Name : ''}<br/>
      🚔 <a href="tel:112" style="color:var(--pink);font-weight:700;text-decoration:underline;">TAP HERE → CALL 112 NOW</a>
    `;

    const msg = encodeURIComponent(
      `🆘 *SOS EMERGENCY ALERT*\n\nI need immediate help!\n\n📍 My GPS Location:\n${mapsLink}\n\nCoordinates: ${lat}°N, ${lng}°E\n\nPlease call me NOW and alert police (112) immediately.\n\n— Sent from ShieldHer Safety App`
    );

    // Send WhatsApp to parent
    if (pPhone) {
      setTimeout(() => window.open(`https://wa.me/${pPhone.replace(/\D/g,'')}?text=${msg}`, '_blank'), 800);
    }
    // Send WhatsApp to 2nd contact
    if (c2Phone) {
      setTimeout(() => window.open(`https://wa.me/${c2Phone.replace(/\D/g,'')}?text=${msg}`, '_blank'), 2000);
    }

    // Prompt to call 112
    setTimeout(() => {
      if (confirm('🚨 SOS alerts sent!\n\nDo you want to call 112 (Police Emergency) now?')) {
        window.location.href = 'tel:112';
      }
    }, 3500);
  };

  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      pos => sendAlerts(pos.coords.latitude.toFixed(6), pos.coords.longitude.toFixed(6)),
      () => {
        locDiv.style.display = 'block';
        locText.textContent = '⚠️ GPS access denied. Enable location in browser settings.';
        status.style.color = '#ff3d8b';
        status.innerHTML = `⚠️ Could not get GPS location.<br/>📞 <a href="tel:112" style="color:var(--pink);font-weight:700;text-decoration:underline;">TAP TO CALL 112 IMMEDIATELY</a>`;
      },
      { enableHighAccuracy: true, timeout: 8000 }
    );
  } else {
    status.innerHTML = `📞 <a href="tel:112" style="color:var(--pink);font-weight:700;">Call 112 immediately</a>`;
  }

  setTimeout(() => {
    btn.style.background = 'linear-gradient(135deg,#ff3d8b,#ff1744)';
    btn.innerHTML = 'SOS<br/>HOLD';
    status.style.color = '';
    status.textContent = 'Hold for 3 seconds → sends your GPS to parent + calls police';
  }, 18000);
}

// REPORT FORM
function submitReport() {
  const type = document.getElementById('f-type').value;
  const desc = document.getElementById('f-desc').value.trim();
  if (!type || !desc) { alert('Please fill in Incident Type and Description.'); return; }
  document.getElementById('reportForm').style.display = 'none';
  document.getElementById('form-success').style.display = 'block';
  setTimeout(() => {
    document.getElementById('reportForm').style.display = 'grid';
    document.getElementById('form-success').style.display = 'none';
    document.querySelectorAll('.form-input,.form-textarea,.form-select').forEach(el => el.value = '');
  }, 7000);
}

// SCROLL REVEAL
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ACTIVE NAV
const sections = document.querySelectorAll('section[id]');
window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(s => { if (window.scrollY >= s.offsetTop - 130) current = s.getAttribute('id'); });
  document.querySelectorAll('.nav-links a').forEach(a => {
    a.style.color = a.getAttribute('href') === `#${current}` ? 'var(--pink)' : '';
  });
});
</script>
