<!-- ══════════ 3. PREVENTIVE MEASURES ══════════ -->
<section id="preventive">
  <div class="section-tag" style="background:rgba(0,230,118,.15);color:var(--green);">🛡️ Prevention First</div>
  <h2 class="section-title">Detailed Preventive <span style="color:var(--green)">Measures</span></h2>
  <p class="section-sub">Prevention is always better than cure. Select a category to see detailed safety measures.</p>

  <div class="prev-tabs">
    <button class="prev-tab active" onclick="showPrev('travel',this)">🚌 Travel</button>
    <button class="prev-tab" onclick="showPrev('digital',this)">💻 Digital Safety</button>

    <button class="prev-tab" onclick="showPrev('night',this)">🌙 Night Safety</button>
