
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShieldHer-22 — Women Safety Portal | Himachal Pradesh</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap');

  :root {
    --bg: #0a0f1e;
    --bg2: #111827;
    --bg3: #1a2235;
    --accent: #e83e8c;
    --accent2: #f97316;
    --accent3: #06b6d4;
    --gold: #fbbf24;
    --text: #f1f5f9;
    --muted: #94a3b8;
    --border: rgba(255,255,255,0.08);
    --card: rgba(255,255,255,0.04);
    --radius: 16px;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: sticky; top:0; z-index:999;
    background: rgba(10,15,30,0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    display: flex; align-items:center; gap:8px;
    flex-wrap: wrap;
    min-height: 60px;
  }
  .nav-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem; font-weight:900;
    color: var(--accent);
    margin-right: 16px; white-space:nowrap;
  }
  nav a {
    color: var(--muted); text-decoration:none;
    font-size: 0.78rem; font-weight:500;
    padding: 6px 10px; border-radius:8px;
    transition: all 0.2s; white-space:nowrap;
  }
  nav a:hover { color:var(--text); background:var(--card); }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 100px 24px 80px;
    text-align: center;
    overflow: hidden;
  }
  .hero::before {
    content:'';
    position:absolute; inset:0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(232,62,140,0.18) 0%, transparent 70%),
                radial-gradient(ellipse 60% 40% at 80% 100%, rgba(6,182,212,0.12) 0%, transparent 60%);
    pointer-events:none;
  }
  .hero-badge {
    display:inline-block;
    background: linear-gradient(135deg, rgba(232,62,140,0.2), rgba(249,115,22,0.2));
    border: 1px solid rgba(232,62,140,0.4);
    color: var(--accent); padding:6px 18px; border-radius:99px;
    font-size:0.82rem; font-weight:600; letter-spacing:0.05em;
    margin-bottom:24px; text-transform:uppercase;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight:900; line-height:1.1;
    margin-bottom:20px;
  }
  .hero h1 span { color: var(--accent); }
  .hero p {
    max-width:640px; margin:0 auto 40px;
    color:var(--muted); font-size:1.05rem;
  }
  .hero-btns { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; }
  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #c2185b);
    color:#fff; padding:14px 28px; border-radius:12px;
    text-decoration:none; font-weight:600; font-size:0.95rem;
    box-shadow: 0 4px 24px rgba(232,62,140,0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(232,62,140,0.5); }
  .btn-secondary {
    background: var(--card);
    border: 1px solid var(--border);
    color:var(--text); padding:14px 28px; border-radius:12px;
    text-decoration:none; font-weight:600; font-size:0.95rem;
    transition: all 0.2s;
  }
  .btn-secondary:hover { background:rgba(255,255,255,0.08); }

  /* ── QUICK NUMBERS ── */
  .quick-numbers {
    display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
    gap:12px; max-width:1100px; margin:0 auto;
    padding:0 24px 60px;
  }
  .qn {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:18px;
    text-align:center;
    transition: border-color 0.2s;
  }
  .qn:hover { border-color: var(--accent); }
  .qn-num { font-size:1.8rem; font-weight:700; color:var(--accent); }
  .qn-label { font-size:0.78rem; color:var(--muted); margin-top:4px; }

  /* ── SECTION ── */
  section {
    max-width:1100px; margin:0 auto;
    padding:60px 24px;
  }
  .section-tag {
    display:inline-block;
    background: rgba(232,62,140,0.12);
    border: 1px solid rgba(232,62,140,0.25);
    color:var(--accent); padding:4px 14px; border-radius:99px;
    font-size:0.75rem; font-weight:600; letter-spacing:0.08em;
    text-transform:uppercase; margin-bottom:14px;
  }
  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight:700; margin-bottom:10px;
  }
  .section-sub { color:var(--muted); max-width:620px; margin-bottom:40px; }

  /* ── HELPLINE CARDS ── */
  .helpline-group { margin-bottom:36px; }
  .helpline-group-title {
    font-size:0.85rem; font-weight:700; letter-spacing:0.1em;
    text-transform:uppercase; color:var(--accent2);
    margin-bottom:16px; padding-bottom:8px;
    border-bottom:1px solid var(--border);
  }
  .helplines-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:16px; }
  .helpline-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:20px;
    display:grid; grid-template-columns:48px 1fr; gap:14px;
    align-items:start; transition:border-color 0.2s, transform 0.2s;
  }
  .helpline-card:hover { border-color:var(--accent); transform:translateY(-2px); }
  .helpline-icon {
    width:48px; height:48px; border-radius:12px;
    background:rgba(232,62,140,0.12);
    display:flex; align-items:center; justify-content:center;
    font-size:1.4rem;
  }
  .helpline-name { font-weight:600; font-size:0.95rem; margin-bottom:2px; }
  .helpline-num {
    font-size:1.4rem; font-weight:700; color:var(--accent);
    font-variant-numeric: tabular-nums; margin-bottom:6px;
  }
  .helpline-num a { color:inherit; text-decoration:none; }
  .helpline-desc { font-size:0.82rem; color:var(--muted); line-height:1.5; }
  .helpline-badge {
    display:inline-block; font-size:0.7rem; font-weight:600;
    background:rgba(6,182,212,0.12); border:1px solid rgba(6,182,212,0.25);
    color:var(--accent3); padding:2px 8px; border-radius:99px;
    margin-top:8px; margin-right:4px;
  }

  /* ── SOS ── */
  #sos { background: var(--bg2); border-radius:24px; padding:50px 24px; margin:0 24px; }
  .sos-inner { max-width:600px; margin:0 auto; text-align:center; }
  .sos-inputs { display:grid; gap:12px; margin:30px 0; text-align:left; }
  .sos-inputs label { font-size:0.82rem; color:var(--muted); margin-bottom:4px; display:block; }
  .sos-inputs input {
    width:100%; padding:12px 16px; border-radius:10px;
    background:var(--bg3); border:1px solid var(--border);
    color:var(--text); font-size:0.9rem; font-family:inherit;
    transition:border-color 0.2s;
  }
  .sos-inputs input:focus { outline:none; border-color:var(--accent); }
  .save-btn {
    width:100%; padding:14px; border-radius:12px;
    background:var(--bg3); border:1px solid var(--border);
    color:var(--text); font-weight:600; cursor:pointer;
    transition:all 0.2s; font-family:inherit;
  }
  .save-btn:hover { background:rgba(232,62,140,0.1); border-color:var(--accent); }
  .save-confirm { color:#4ade80; font-size:0.85rem; margin-top:10px; display:none; }
  .sos-btn {
    width:140px; height:140px; border-radius:50%;
    background: radial-gradient(circle, #ff1744, #c2185b);
    border:4px solid rgba(255,23,68,0.3);
    color:#fff; font-size:1.5rem; font-weight:900;
    cursor:pointer; margin:30px auto; display:flex;
    flex-direction:column; align-items:center; justify-content:center;
    box-shadow: 0 0 0 0 rgba(255,23,68,0.4);
    animation: pulse 2.5s infinite;
    transition:transform 0.1s;
    user-select:none;
  }
  .sos-btn span { font-size:0.7rem; font-weight:600; margin-top:2px; opacity:0.8; }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(255,23,68,0.4); }
    70% { box-shadow: 0 0 0 24px rgba(255,23,68,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,23,68,0); }
  }
  .sos-features {
    display:grid; grid-template-columns:repeat(auto-fit,minmax(130px,1fr));
    gap:10px; margin-top:24px;
  }
  .sos-feat {
    background:var(--bg3); border:1px solid var(--border);
    border-radius:10px; padding:12px; font-size:0.78rem;
    color:var(--muted); text-align:center;
  }
  .sos-feat strong { display:block; color:var(--text); font-size:0.85rem; margin-bottom:2px; }
  #gps-status { color:var(--accent3); font-size:0.85rem; margin-top:12px; }

  /* ── PREVENTIVE TABS ── */
  .tabs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:24px; }
  .tab {
    padding:8px 18px; border-radius:99px;
    background:var(--card); border:1px solid var(--border);
    color:var(--muted); font-size:0.82rem; font-weight:500;
    cursor:pointer; transition:all 0.2s;
  }
  .tab.active, .tab:hover { background:rgba(232,62,140,0.12); border-color:var(--accent); color:var(--text); }
  .preventive-content { display:none; }
  .preventive-content.active { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:16px; }
  .prev-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:20px;
    transition:border-color 0.2s;
  }
  .prev-card:hover { border-color:var(--accent2); }
  .prev-card-icon { font-size:1.6rem; margin-bottom:10px; }
  .prev-card h4 { font-size:0.95rem; font-weight:600; margin-bottom:6px; }
  .prev-card ul { padding-left:18px; }
  .prev-card ul li { font-size:0.82rem; color:var(--muted); margin-bottom:4px; }

  /* ── TIPS ── */
  .tips-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px; }
  .tip-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:22px;
    display:flex; gap:16px; align-items:flex-start;
  }
  .tip-num {
    font-family:'Playfair Display',serif;
    font-size:1.8rem; font-weight:900;
    color:rgba(232,62,140,0.2); line-height:1; min-width:36px;
  }
  .tip-icon { font-size:1.5rem; min-width:32px; }
  .tip-title { font-weight:600; font-size:0.95rem; margin-bottom:4px; }
  .tip-desc { font-size:0.82rem; color:var(--muted); }

  /* ── DISTRICTS ── */
  .district-search { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:24px; }
  .district-search input {
    flex:1; min-width:200px; padding:12px 16px; border-radius:10px;
    background:var(--bg3); border:1px solid var(--border);
    color:var(--text); font-size:0.9rem; font-family:inherit;
  }
  .district-search input:focus { outline:none; border-color:var(--accent3); }
  .district-tabs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:20px; }
  .dtab {
    padding:6px 14px; border-radius:99px; cursor:pointer;
    background:var(--card); border:1px solid var(--border);
    color:var(--muted); font-size:0.78rem; transition:all 0.2s;
  }
  .dtab.active { background:rgba(6,182,212,0.12); border-color:var(--accent3); color:var(--text); }
  .districts-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:14px; }
  .district-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:18px;
    transition:border-color 0.2s;
  }
  .district-card:hover { border-color:var(--accent3); }
  .district-card h4 { font-weight:700; font-size:1rem; margin-bottom:8px; }
  .district-card p { font-size:0.8rem; color:var(--muted); margin-bottom:4px; }
  .district-card a { color:var(--accent3); text-decoration:none; font-weight:600; }
  .no-result { color:var(--muted); font-style:italic; }

  /* ── SELF DEFENSE ── */
  .sd-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:16px; }
  .sd-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:22px;
    transition:border-color 0.2s;
  }
  .sd-card:hover { border-color:var(--gold); }
  .sd-icon { font-size:1.8rem; margin-bottom:10px; }
  .sd-level {
    display:inline-block; font-size:0.72rem; font-weight:700;
    background:rgba(251,191,36,0.12); border:1px solid rgba(251,191,36,0.25);
    color:var(--gold); padding:2px 10px; border-radius:99px;
    margin-bottom:12px;
  }
  .sd-card h4 { font-weight:700; font-size:1rem; margin-bottom:10px; }
  .sd-card ol { padding-left:18px; }
  .sd-card ol li { font-size:0.82rem; color:var(--muted); margin-bottom:5px; }

  /* ── RIGHTS ── */
  .rights-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:16px; }
  .right-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:22px;
    border-left:3px solid var(--accent);
  }
  .right-tag {
    font-size:0.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:0.1em; color:var(--accent2); margin-bottom:8px;
  }
  .right-card h4 { font-weight:700; margin-bottom:8px; }
  .right-card p { font-size:0.83rem; color:var(--muted); margin-bottom:10px; }
  .right-law { font-size:0.75rem; color:var(--accent3); font-style:italic; }

  /* ── PREDICTOR ── */
  #predictor { background:var(--bg2); border-radius:24px; padding:50px 24px; margin:0 24px; }
  .predictor-inner { max-width:640px; margin:0 auto; }
  .pred-form { display:grid; gap:16px; margin:30px 0; }
  .pred-form input, .pred-form select {
    padding:12px 16px; border-radius:10px;
    background:var(--bg3); border:1px solid var(--border);
    color:var(--text); font-size:0.9rem; font-family:inherit;
  }
  .pred-form select option { background:var(--bg); }
  .pred-form input:focus, .pred-form select:focus { outline:none; border-color:var(--accent); }
  .pred-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .pred-btn {
    padding:14px; border-radius:12px;
    background:linear-gradient(135deg,var(--accent),#c2185b);
    color:#fff; border:none; font-weight:700; cursor:pointer;
    font-size:0.95rem; font-family:inherit;
    box-shadow:0 4px 24px rgba(232,62,140,0.3);
    transition:transform 0.2s;
  }
  .pred-btn:hover { transform:translateY(-2px); }
  .score-display {
    text-align:center; padding:30px;
    background:var(--bg3); border-radius:16px;
    border:1px solid var(--border); display:none;
  }
  .score-num {
    font-family:'Playfair Display',serif;
    font-size:4rem; font-weight:900;
  }
  .score-label { color:var(--muted); font-size:0.9rem; }
  .score-tips { margin-top:20px; text-align:left; }
  .score-tips li { font-size:0.83rem; color:var(--muted); margin-bottom:6px; padding-left:4px; }

  /* ── CHARTS ── */
  .chart-tabs { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:24px; }
  .chart-tab {
    padding:8px 18px; border-radius:99px; cursor:pointer;
    background:var(--card); border:1px solid var(--border);
    color:var(--muted); font-size:0.82rem; transition:all 0.2s;
  }
  .chart-tab.active { background:rgba(232,62,140,0.12); border-color:var(--accent); color:var(--text); }
  .chart-view { display:none; }
  .chart-view.active { display:block; }
  .chart-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; margin-bottom:24px; }
  .stat-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:18px; text-align:center;
  }
  .stat-label { font-size:0.75rem; color:var(--muted); margin-bottom:4px; }
  .stat-val { font-size:1.8rem; font-weight:700; color:var(--accent); }
  .stat-sub { font-size:0.72rem; color:var(--muted); }
  .bar-chart { display:grid; gap:10px; }
  .bar-row { display:grid; grid-template-columns:110px 1fr 50px; align-items:center; gap:10px; }
  .bar-district { font-size:0.78rem; color:var(--muted); }
  .bar-track { background:rgba(255,255,255,0.05); border-radius:99px; height:10px; overflow:hidden; }
  .bar-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,var(--accent),var(--accent2)); transition:width 0.8s; }
  .bar-val { font-size:0.78rem; color:var(--muted); text-align:right; }
  .safety-index { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; }
  .si-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:var(--radius); padding:16px; text-align:center;
  }
  .si-score { font-size:1.6rem; font-weight:700; margin:6px 0; }
  .si-name { font-size:0.8rem; color:var(--muted); }
  .pie-legend { display:flex; flex-wrap:wrap; gap:10px; margin-top:16px; }
  .pie-item { display:flex; align-items:center; gap:6px; font-size:0.8rem; }
  .pie-dot { width:10px; height:10px; border-radius:50%; }
  .trend-chart { display:grid; gap:8px; }
  .trend-row { display:grid; grid-template-columns:50px 1fr 70px; align-items:center; gap:10px; }
  .trend-year { font-size:0.78rem; color:var(--muted); }
  .trend-bar { background:rgba(255,255,255,0.05); border-radius:99px; height:8px; overflow:hidden; }
  .trend-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,var(--accent3),var(--accent)); }
  .trend-val { font-size:0.78rem; text-align:right; }
  .trend-val.down { color:#4ade80; }
  .trend-val.up { color:#f87171; }

  /* ── REPORT ── */
  .report-form { display:grid; gap:16px; max-width:680px; }
  .report-form input, .report-form select, .report-form textarea {
    width:100%; padding:12px 16px; border-radius:10px;
    background:var(--bg3); border:1px solid var(--border);
    color:var(--text); font-size:0.9rem; font-family:inherit;
    transition:border-color 0.2s;
  }
  .report-form textarea { min-height:120px; resize:vertical; }
  .report-form input:focus, .report-form select:focus, .report-form textarea:focus {
    outline:none; border-color:var(--accent);
  }
  .report-form select option { background:var(--bg); }
  .report-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .anon-note { font-size:0.8rem; color:var(--muted); }
  .submit-btn {
    padding:14px 32px; border-radius:12px;
    background:linear-gradient(135deg,var(--accent),#c2185b);
    color:#fff; border:none; font-weight:700; cursor:pointer;
    font-size:0.95rem; font-family:inherit;
    transition:transform 0.2s;
  }
  .submit-btn:hover { transform:translateY(-2px); }
  .submit-confirm { color:#4ade80; font-size:0.88rem; margin-top:10px; display:none; }

  /* ── FOOTER ── */
  footer {
    background:var(--bg2);
    border-top:1px solid var(--border);
    padding:40px 24px;
    text-align:center;
  }
  .footer-brand {
    font-family:'Playfair Display',serif;
    font-size:1.5rem; font-weight:900; color:var(--accent);
    margin-bottom:8px;
  }
  .footer-sub { color:var(--muted); font-size:0.85rem; margin-bottom:24px; }
  .footer-nums { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-bottom:24px; }
  .footer-num {
    background:var(--card); border:1px solid var(--border);
    border-radius:10px; padding:8px 16px;
    font-size:0.82rem; color:var(--muted);
  }
  .footer-num strong { color:var(--accent); }
  .footer-copy { font-size:0.75rem; color:rgba(148,163,184,0.5); }

  /* ── UTIL ── */
  .divider { border:none; border-top:1px solid var(--border); margin:0; }
  @media(max-width:600px) {
    .report-row, .pred-row { grid-template-columns:1fr; }
    .bar-row { grid-template-columns:80px 1fr 40px; }
    nav { gap:4px; }
    nav a { font-size:0.72rem; padding:4px 8px; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-brand">🛡️ ShieldHer-22 HP</div>
  <a href="#predictor">🔥 Safety Score</a>
  <a href="#charts">📊 Charts</a>
  <a href="#helplines">Helplines</a>
